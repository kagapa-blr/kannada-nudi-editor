{
  "name": "kannada-editor",
  "version": "1.0.0",
  "description": "Kannada Text Editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:css": "postcss assets/tailwind.css -o dist/output.css"
  },
  "build": {
    "appId": "com.kannada.editor",
    "productName": "Kannada Editor",
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  },
  "dependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.16"
  }
}
